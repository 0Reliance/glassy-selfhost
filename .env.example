# Glassy self-host — copy to `.env` and fill in the four required fields.
# All other variables have safe defaults baked into docker-compose.yml;
# uncomment + customize any of these as needed.

# ── Required: Glassy membership ────────────────────────────────────────────
# Your Glassy account email (Clear or Pro). The appliance verifies your
# membership at boot and will not start without a valid subscription.
# Sign up at https://clear.glassy.fyi or https://glassy.fyi if needed.
GLASSY_MEMBER_EMAIL=

# ── Required: self-host pairing token ───────────────────────────────────────
# Prevents anyone who merely knows your email from spinning up an unlocked
# instance using your membership. Generate a token in your Glassy account at
# https://app.glassy.fyi → Settings → Self-hosting, then paste it here.
# The token is stored hashed on the cloud; only you see the raw value once.
# Rotate it any time from the same settings page (the old token stops working
# on the next 30-day re-verification, or immediately if you destroy the cache).
GLASSY_SELFHOST_TOKEN=

# ── Required: two secrets (generate with `openssl rand -hex 32`) ────────────
JWT_SECRET=
API_KEY_ENCRYPTION_KEY=

# ── Core identity / URLs ────────────────────────────────────────────────────
# APP_URL is the public origin Glassy tells OAuth + email links to use.
# For Tailscale / LAN access, set this to your tailnet or LAN URL.
APP_URL=http://localhost:3000

# Comma-separated origins allowed to call the API. Defaults to localhost.
# For Tailscale / multi-device, add your tailnet hostname or LAN origin here,
# e.g. CORS_ORIGINS=http://localhost:3000,http://glassy.tail-net.ts.net:3000
CORS_ORIGINS=http://localhost:3000

# Glassy image tag from GHCR. Pin for reproducibility; use `latest` for rolling.
GLASSY_TAG=latest

# Host port Glassy listens on. Change this if port 3000 is already in use
# (e.g. by another dev tool). When you change it, also update APP_URL and
# CORS_ORIGINS below to match. The container always listens on 8080 internally;
# this only changes the host-side mapping.
APP_PORT=3000

# ── Single-user defaults ────────────────────────────────────────────────────
# Private mode hides all public surfaces from logged-out visitors.
# The seeded admin account is the only account on this instance.
#
# ⚠️  NOTE: INSTANCE_ID and INSTANCE_ACCESS_MODE_DEFAULT are hardcoded in
# docker-compose.yml and CANNOT be overridden here. They are security
# boundaries — overriding them via .env could turn your private appliance
# into a public instance. This entry is for reference only.
INSTANCE_ACCESS_MODE_DEFAULT=private

# Registration is permanently disabled on the single-user appliance.
# The server enforces this regardless of any setting here — do not add
# an ALLOW_REGISTRATION line. To run more than one workspace, create
# sub-accounts from Settings → Accounts (one owner, isolated workspaces).
# See docs/SELF_HOSTED_DEPLOYMENT.md § Account management.

# Tells the app it's running locally (hides the cloud-limitation banner
# in Obsidian settings, etc.). Do not change.
DEPLOYMENT_LOCALITY=local

# ── Feature flags ───────────────────────────────────────────────────────────
# MCP server + Second Brain (recommended ON for self-host).
ENABLE_MCP_SERVER=true

# Agent Gateway (OpenClaw / Hermes). Self-host-appropriate (requires localhost).
ENABLE_AGENT_GATEWAY=true

# ── Host networking ─────────────────────────────────────────────────────────
# Rewrites 127.0.0.1 to the Docker host gateway so container can reach
# Obsidian / Ollama on the host. Do not change.
OBSIDIAN_HOST_OVERRIDE=host.docker.internal

# Additional hostnames/IPs allowed for Obsidian Local REST API connections.
# Comma-separated. Use this when Obsidian is on a different machine (LAN IP),
# a Tailscale node, or a WSL2 bridge address that the default allowlist
# doesn't cover. Self-hosted only — ignored on cloud instances.
# Example: OBSIDIAN_NETWORK_ALLOWLIST=192.168.1.10,glassy.tail-net.ts.net
# OBSIDIAN_NETWORK_ALLOWLIST=

# ── AI providers ────────────────────────────────────────────────────────
# Local AI works out of the box: in-browser WebGPU models, or Ollama on the
# host (reachable via host.docker.internal). No key required.
#
# For cloud AI (Gemini / OpenAI / Anthropic), add your own key IN THE APP at
# Settings → API Keys (BYOK). On the appliance, cloud API keys are NOT read
# from this file — they are stored encrypted per-account in the database.

# Ollama endpoint for local AI. Inside the container, `localhost` is the
# container itself — use host.docker.internal to reach Ollama on the host.
# The server auto-appends /v1 if missing, so both with and without /v1 work.
# If using the bundled ollama sidecar (docker-compose.ollama.yml), use
# http://ollama:11434 instead.
# OLLAMA_BASE_URL=http://host.docker.internal:11434
# Default Ollama model to use when none is selected in the app.
# OLLAMA_MODEL=llama3.2

# ── Transactional email (disabled on the appliance) ─────────────────────────
# Email is permanently OFF on the self-hosted appliance — nothing leaves the
# machine, so these variables are no-ops here. Password reset uses the local
# recovery paths instead (admin reset, or secret recovery key — see
# docs/SELF_HOSTED_DEPLOYMENT.md § Account recovery).
# RESEND_API_KEY=
# EMAIL_FROM=Glassy <noreply@glassy.fyi>
# EMAIL_REPLY_TO=support@glassy.fyi

# ── Optional infra ──────────────────────────────────────────────────────────
# TRUST_PROXY=2                       # set to 1 if behind a single reverse proxy
#
# Glassy always takes an automatic daily backup at 02:00 (plain SQLite copies
# in /app/data/backups, ~7 days kept) — no config needed. The variables below
# only affect the on-demand backup CLI (`node server/utils/backup.js`):
# BACKUP_DIR=/app/data/backups        # where the CLI writes (default shown)
# BACKUP_RETENTION_DAYS=30            # CLI retention in days (default 30)
# Encrypt CLI backups (recommended for off-machine copies). Generate with
# `openssl rand -hex 32` and store the key somewhere safe OFF the machine —
# without it, encrypted backups cannot be restored.
# BACKUP_ENCRYPTION_KEY=

# ── Advanced tuning (optional) ──────────────────────────────────────────────
# Worker processes. Defaults to min(2, CPUs-1). Raise on a multi-core host
# for more throughput; set to 1 on a small box to save memory.
# CLUSTER_WORKERS=2

# MCP tool-call rate limits (per hour). The self-host owner is on the Pro
# tier, so the PRO limit applies. Raise it if heavy agent/MCP automation
# hits the ceiling; there is no billing on the appliance.
# MCP_PRO_TOOLCALLS_PER_HOUR=1200
# MCP_FREE_TOOLCALLS_PER_HOUR=120

# Obsidian tuning — raise the timeout for a slow host or a large vault, and
# the import caps if you import a big vault in one go.
# OBSIDIAN_REQUEST_TIMEOUT_MS=10000       # per-request timeout (ms)
# OBSIDIAN_IMPORT_MAX_ENTRIES=5000        # max notes per import
# OBSIDIAN_IMPORT_MAX_TOTAL_BYTES=209715200   # 200 MB total per import
# OBSIDIAN_IMPORT_MAX_PER_FILE_BYTES=5242880  # 5 MB per file