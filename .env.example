# Glassy self-host — copy to `.env` and fill in the two required secrets.
# All other variables have safe defaults baked into docker-compose.yml;
# uncomment + customize any of these as needed.

# ── Required: two secrets (generate with `openssl rand -hex 32`) ────────────
JWT_SECRET=
API_KEY_ENCRYPTION_KEY=

# ── Core identity / URLs ────────────────────────────────────────────────────
APP_URL=http://localhost:3000
CORS_ORIGINS=http://localhost:3000
GLASSY_TAG=latest

# ── Single-user defaults ────────────────────────────────────────────────────
INSTANCE_ACCESS_MODE_DEFAULT=private
# Registration is permanently disabled. To run more than one workspace,
# create sub-accounts from Settings → Accounts.
# See SELF_HOSTED_DEPLOYMENT.md § Account management.
DEPLOYMENT_LOCALITY=local

# ── Feature flags ───────────────────────────────────────────────────────────
ENABLE_MCP_SERVER=true
ENABLE_AGENT_GATEWAY=true

# ── Host networking ─────────────────────────────────────────────────────────
OBSIDIAN_HOST_OVERRIDE=host.docker.internal

# ── AI providers ────────────────────────────────────────────────────────────
# Local AI works out of the box (WebGPU or Ollama on the host).
# For cloud AI, add your key IN THE APP at Settings → API Keys (BYOK).
# Cloud API keys are NOT read from this file on the appliance.
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=llama3.2

# ── Transactional email (disabled on the appliance) ─────────────────────────
# Email is permanently OFF — nothing leaves the machine.
# Password reset uses local recovery paths (see SELF_HOSTED_DEPLOYMENT.md).
# RESEND_API_KEY=

# ── Optional infra ──────────────────────────────────────────────────────────
# TRUST_PROXY=1                       # set to 1 if behind a single reverse proxy
# BACKUP_DIR=/app/data/backups        # where the CLI writes (default shown)
# BACKUP_RETENTION_DAYS=30            # CLI retention in days
# BACKUP_ENCRYPTION_KEY=              # AES-256-GCM; generate: openssl rand -hex 32

# ── Advanced tuning (optional) ──────────────────────────────────────────────
# CLUSTER_WORKERS=2
# MCP_PRO_TOOLCALLS_PER_HOUR=1200
# MCP_FREE_TOOLCALLS_PER_HOUR=120
# OBSIDIAN_REQUEST_TIMEOUT_MS=10000
# OBSIDIAN_IMPORT_MAX_ENTRIES=5000
# OBSIDIAN_IMPORT_MAX_TOTAL_BYTES=209715200
# OBSIDIAN_IMPORT_MAX_PER_FILE_BYTES=5242880
